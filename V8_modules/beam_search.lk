// ========================================
// Beam Search Action Discovery Module
// ========================================
// Bottom-up search that builds action sequences one action at a time,
// keeping the B best partial sequences at each depth level.
// Produces B complete scenarios injected alongside template scenarios.

include('item_roles.lk')
include('cache_manager.lk')
include('reachable_graph.lk')

// Beam search entry point
// Returns array of scenarios (each scenario = array of Action objects)
function beamSearchScenarios(playerObj, targetObj, arsenalObj, fieldMapObj) {
    if (targetObj == null) return []

    var beamWidth = 20
    var maxDepth = 10

    var playerPos = playerObj._cellPos
    var targetPos = targetObj._cellPos
    var str = playerObj._strength
    var mag = playerObj._magic
    var wis = playerObj._wisdom
    var sci = playerObj._science
    var currentWeapon = getWeapon()

    // Pre-compute weapon max uses from API (DB weapons have hardcoded _maxUse=1)
    var weaponMaxUses = [:]
    for (var wid in mapKeys(arsenalObj.playerEquippedWeapons)) {
        weaponMaxUses[wid] = getWeaponMaxUses(wid)
    }

    var agi = playerObj._agility

    // Seed beam with empty candidate
    var beam = []
    push(beam, [
        'actions': [],
        'simTP': getTP(),
        'simMP': getMP(),
        'simPos': playerPos,
        'simWeapon': currentWeapon,
        'simStr': str,
        'simMag': mag,
        'simWis': wis,
        'simSci': sci,
        'simAgi': agi,
        'chipUsed': [:],
        'weaponUses': [:],
        'cumScore': 0,
        'cumDamage': 0,
        'moveCount': 0,   // Allow multiple moves (e.g. approach + reposition)
        'wMaxUses': weaponMaxUses
    ])

    for (var depth = 0; depth < maxDepth; depth++) {
        var allCandidates = []

        for (var partial in beam) {
            if (partial['simTP'] < 3 && partial['simMP'] < 1) {
                // Terminal — keep as-is
                push(allCandidates, partial)
                continue
            }

            var legalActions = beamGetLegalActions(partial, targetObj, arsenalObj)

            if (count(legalActions) == 0) {
                // No legal actions — terminal
                push(allCandidates, partial)
                continue
            }

            for (var actionInfo in legalActions) {
                var value = beamEvaluateAction(actionInfo, partial, targetObj, arsenalObj, playerObj)
                var newCandidate = beamExtendCandidate(partial, actionInfo, value, targetObj)
                push(allCandidates, newCandidate)
            }
        }

        if (count(allCandidates) == 0) break

        // Diversity-aware beam selection
        // Top 14 by cumulative score
        arraySort(allCandidates, function(a, b) {
            return b['cumScore'] - a['cumScore']
        })

        beam = []
        var selected = [:]  // Track selected candidate indices
        var limit = min(14, count(allCandidates))
        for (var i = 0; i < limit; i++) {
            push(beam, allCandidates[i])
            selected[i] = true
        }

        // Reserve 3 slots for defensive candidates (shield/heal/retreat)
        var defAdded = 0
        for (var i = 0; i < count(allCandidates) && defAdded < 3; i++) {
            if (mapContainsKey(selected, i)) continue
            if (beamHasDefensiveAction(allCandidates[i])) {
                push(beam, allCandidates[i])
                selected[i] = true
                defAdded++
            }
        }

        // Reserve 3 slots for utility candidates (denial/buff/poison)
        var utilAdded = 0
        for (var i = 0; i < count(allCandidates) && utilAdded < 3; i++) {
            if (mapContainsKey(selected, i)) continue
            if (beamHasUtilityAction(allCandidates[i])) {
                push(beam, allCandidates[i])
                selected[i] = true
                utilAdded++
            }
        }

        // Ops budget check
        if (getOperations() > 11500000) break
    }

    // Convert beam candidates to scenario format (array of Action objects)
    var scenarios = []
    for (var candidate in beam) {
        if (count(candidate['actions']) > 0) {
            push(scenarios, candidate['actions'])
        }
    }
    return scenarios
}

// Generate all legal actions from current beam candidate state
function beamGetLegalActions(partial, targetObj, arsenalObj) {
    var actions = []
    var simTP = partial['simTP']
    var simMP = partial['simMP']
    var simPos = partial['simPos']
    var simWeapon = partial['simWeapon']
    var chipUsed = partial['chipUsed']
    var weaponUses = partial['weaponUses']
    var wMaxUses = partial['wMaxUses']
    var targetPos = targetObj._cellPos
    var dist = getCellDistance(simPos, targetPos)

    // 1. All equipped chips
    for (var chipId in mapKeys(arsenalObj.playerEquippedChips)) {
        var chipObj = arsenalObj.playerEquippedChips[chipId]
        var cost = chipObj._cost
        if (cost > simTP) continue
        if (mapContainsKey(chipUsed, chipId)) continue

        // Check cooldown (real game state)
        var cd = getCooldown(chipId, getEntity())
        if (cd > 0) continue

        // Determine target cell and check range
        var chipTargetCell = -1
        var isSelfTarget = false

        if (isHealingChip(chipId) || isOffensiveBuff(chipId) || isShieldChip(chipId) ||
            isDamageReturnChip(chipId) || isResourceChip(chipId)) {
            // Self-targeted
            chipTargetCell = simPos
            isSelfTarget = true
        } else if (isUtilityChip(chipId)) {
            // Skip positioning chips — handled separately
            if (chipId == CHIP_TELEPORTATION) continue
            if (chipId == CHIP_INVERSION && _isBossFight) continue
            // Grapple/Boxing Glove: target enemy
            chipTargetCell = targetPos
        } else {
            // Damage/poison/debuff: target enemy
            chipTargetCell = targetPos
        }

        // Range check for non-self chips
        if (!isSelfTarget && chipTargetCell != -1) {
            var chipDist = getCellDistance(simPos, chipTargetCell)
            if (chipDist == null || chipDist < chipObj._minRange || chipDist > chipObj._maxRange) continue
        }

        // Classify action type
        var actionType = Action.ACTION_BUFF
        if (isPoisonChip(chipId)) {
            actionType = Action.ACTION_DOT
        } else if (isDebuffChip(chipId)) {
            actionType = Action.ACTION_DEBUFF
        } else if (!isHealingChip(chipId) && !isOffensiveBuff(chipId) && !isShieldChip(chipId) &&
                   !isDamageReturnChip(chipId) && !isResourceChip(chipId) && !isUtilityChip(chipId)) {
            // Damage chip (not in any buff/heal/debuff category)
            actionType = Action.ACTION_DIRECT
        }

        push(actions, [
            'type': 'chip',
            'actionType': actionType,
            'id': chipId,
            'targetCell': chipTargetCell,
            'cost': cost,
            'isSelf': isSelfTarget
        ])
    }

    // 2. Current weapon
    if (simWeapon != null && simWeapon != -1) {
        var wCost = 0
        var weaponObj = null
        if (mapContainsKey(arsenalObj.playerEquippedWeapons, simWeapon)) {
            weaponObj = arsenalObj.playerEquippedWeapons[simWeapon]
            wCost = weaponObj._cost
        }
        if (weaponObj != null && wCost <= simTP) {
            var currentUses = 0
            if (mapContainsKey(weaponUses, simWeapon)) currentUses = weaponUses[simWeapon]
            var maxUse = mapContainsKey(wMaxUses, simWeapon) ? wMaxUses[simWeapon] : 1
            if (currentUses < maxUse) {
                if (dist != null && dist >= weaponObj._minRange && dist <= weaponObj._maxRange &&
                    lineOfSight(simPos, targetPos)) {
                    push(actions, [
                        'type': 'weapon',
                        'actionType': Action.ACTION_DIRECT,
                        'id': simWeapon,
                        'targetCell': targetPos,
                        'cost': wCost,
                        'isSelf': false,
                        'needsSwap': false
                    ])
                }
            }
        }
    }

    // 3. Other weapons (with swap)
    for (var wid in mapKeys(arsenalObj.playerEquippedWeapons)) {
        if (wid == simWeapon) continue
        var weaponObj = arsenalObj.playerEquippedWeapons[wid]
        var totalCost = 1 + weaponObj._cost  // swap + attack
        if (totalCost > simTP) continue
        var currentUses = 0
        if (mapContainsKey(weaponUses, wid)) currentUses = weaponUses[wid]
        var maxUse = mapContainsKey(wMaxUses, wid) ? wMaxUses[wid] : 1
        if (currentUses >= maxUse) continue
        if (dist != null && dist >= weaponObj._minRange && dist <= weaponObj._maxRange &&
            lineOfSight(simPos, targetPos)) {
            push(actions, [
                'type': 'weapon',
                'actionType': Action.ACTION_DIRECT,
                'id': wid,
                'targetCell': targetPos,
                'cost': totalCost,
                'isSelf': false,
                'needsSwap': true
            ])
        }
    }

    // 4. Movement (allow up to 2 moves per sequence — approach + reposition)
    if (simMP > 0 && partial['moveCount'] < 2) {
        var moveCells = beamGetMoveCells(simPos, targetPos, simMP, arsenalObj, partial)
        for (var moveCell in moveCells) {
            push(actions, [
                'type': 'move',
                'actionType': Action.MOVEMENT_APPROACH,
                'id': -1,
                'targetCell': moveCell,
                'cost': 0,  // MP cost, not TP
                'isSelf': true,
                'mpCost': getGraphMPCost(moveCell)
            ])
        }
    }

    return actions
}

// Get candidate movement cells (toward target, optimal weapon range, cover, kiting)
function beamGetMoveCells(simPos, targetPos, simMP, arsenalObj, partial) {
    var cells = []
    var reachable = getReachableCells()
    if (count(reachable) == 0) return cells

    var currentDist = getCellDistance(simPos, targetPos)
    if (currentDist == null) return cells

    var bestApproachCell = -1
    var bestApproachDist = currentDist

    var bestKiteCell = -1
    var bestKiteDist = currentDist

    // Find optimal weapon range cell (maximizes attacks in range)
    var bestWeaponCell = -1
    var bestWeaponScore = -1

    for (var cell in reachable) {
        if (cell == simPos) continue
        var mpCost = getGraphMPCost(cell)
        if (mpCost > simMP || mpCost <= 0) continue

        var d = getCellDistance(cell, targetPos)
        if (d == null) continue

        // Best approach cell (closest to enemy)
        if (d < bestApproachDist) {
            bestApproachDist = d
            bestApproachCell = cell
        }
        // Best kite cell (farthest from enemy)
        if (d > bestKiteDist) {
            bestKiteDist = d
            bestKiteCell = cell
        }
        // Best weapon range cell (most weapons/chips in range)
        var weaponScore = 0
        for (var wid in mapKeys(arsenalObj.playerEquippedWeapons)) {
            var wObj = arsenalObj.playerEquippedWeapons[wid]
            if (d >= wObj._minRange && d <= wObj._maxRange) {
                // Weight by damage potential
                var bd = getCachedDamageBreakdown(wid)
                if (bd != null) weaponScore += bd['total']
                else weaponScore += 100
            }
        }
        // Also count attack chips in range
        for (var chipId in mapKeys(arsenalObj.playerEquippedChips)) {
            if (mapContainsKey(partial['chipUsed'], chipId)) continue
            if (isHealingChip(chipId) || isOffensiveBuff(chipId) || isShieldChip(chipId) ||
                isDamageReturnChip(chipId) || isResourceChip(chipId) || isUtilityChip(chipId)) continue
            var chipObj = arsenalObj.playerEquippedChips[chipId]
            if (d >= chipObj._minRange && d <= chipObj._maxRange) {
                var bd = getCachedDamageBreakdown(chipId)
                if (bd != null) weaponScore += bd['total']
                else weaponScore += 50
            }
        }
        if (weaponScore > bestWeaponScore) {
            bestWeaponScore = weaponScore
            bestWeaponCell = cell
        }
    }

    if (bestApproachCell != -1) push(cells, bestApproachCell)
    if (bestWeaponCell != -1 && bestWeaponCell != bestApproachCell) push(cells, bestWeaponCell)
    if (bestKiteCell != -1 && bestKiteCell != bestApproachCell && bestKiteCell != bestWeaponCell) push(cells, bestKiteCell)

    return cells
}

// Evaluate an action's value given the current partial candidate state
function beamEvaluateAction(actionInfo, partial, targetObj, arsenalObj, playerObj) {
    var value = 0
    var simStr = partial['simStr']
    var simMag = partial['simMag']
    var simWis = partial['simWis']
    var simSci = partial['simSci']
    var cumDamage = partial['cumDamage']
    var enemyHP = targetObj._currHealth

    if (actionInfo['type'] == 'chip') {
        var chipId = actionInfo['id']

        // Damage chips
        if (actionInfo['actionType'] == Action.ACTION_DIRECT) {
            var bd = arsenalObj.getDamageBreakdown(simStr, simMag, simWis, simSci, chipId)
            var dmg = bd['direct'] + bd['nova']
            value += dmg * 2.0

            // Nova bonus: permanent MaxHP reduction is extra valuable
            if (bd['nova'] > 0) {
                value += bd['nova'] * 1.5
            }

            // Kill proximity bonus
            if (enemyHP > 0 && (cumDamage + dmg) / enemyHP > 0.7) {
                value *= 3.0
            }
        }
        // Poison chips
        else if (isPoisonChip(chipId)) {
            var bd = arsenalObj.getDamageBreakdown(simStr, simMag, simWis, simSci, chipId)
            var dot = bd['dot']
            value += dot * 1.5

            // Stack bonus if other poisons already used
            var poisonCount = 0
            for (var a in partial['actions']) {
                if (a.type == Action.ACTION_DOT) poisonCount++
            }
            if (poisonCount > 0) value += 100 * poisonCount

            // Antidote awareness: scale by antidote multiplier
            var antidoteCd = 0
            var tracker = new CooldownTracker(targetObj)
            antidoteCd = tracker.getCooldownRemaining(targetObj._id, CooldownTracker.CHIP_ANTIDOTE_ID)
            if (antidoteCd >= 3) value *= 1.5  // Safe dump window
            else if (antidoteCd == 0) value *= 0.3  // Antidote ready — low value
        }
        // Offensive buffs
        else if (isOffensiveBuff(chipId)) {
            if (chipId == CHIP_WIZARDRY) {
                value += 200
                // Enablement: check remaining poison/denial chips
                var unusedPoison = beamCountUnusedPoisonChips(partial, arsenalObj)
                var unusedDenial = beamCountUnusedDenialChips(partial, arsenalObj)
                if (unusedPoison > 0) value += 200 * unusedPoison
                if (unusedDenial > 0) value += 200 * unusedDenial
            } else if (chipId == CHIP_PRISM) {
                value += 180
                // Enablement: bonus if unused Nova weapon
                if (beamHasUnusedNovaWeapon(partial, arsenalObj)) value += 300
                // Bonus for shields remaining
                var unusedShields = beamCountUnusedShieldChips(partial, arsenalObj)
                if (unusedShields > 0) value += 150
            } else if (chipId == CHIP_STEROID || chipId == CHIP_DOPING) {
                value += 200
                // Enablement: bonus if STR-scaling weapons remain
                var unusedWeapons = beamCountUnusedWeapons(partial, arsenalObj)
                if (unusedWeapons > 0) value += 250
            } else if (chipId == CHIP_KNOWLEDGE) {
                value += 150
                // Enablement: healing chips benefit from WIS
                var unusedHeals = beamCountUnusedHealChips(partial, arsenalObj)
                if (unusedHeals > 0) value += 100 * unusedHeals
            } else if (chipId == CHIP_WARM_UP) {
                value += 200
                // Enablement: damage return benefits from AGI
                var unusedReturn = beamCountUnusedReturnChips(partial, arsenalObj)
                if (unusedReturn > 0) value += 200
                // Weapons benefit from crit chance boost too
                var unusedWeaponsWU = beamCountUnusedWeapons(partial, arsenalObj)
                if (unusedWeaponsWU > 0) value += 150
            } else if (chipId == CHIP_ADRENALINE) {
                value += 400  // Very high: +5 TP unlocks many actions
            } else if (chipId == CHIP_ARMORING) {
                value += 120  // +25-30 MaxHP permanent
            } else if (chipId == CHIP_ELEVATION) {
                value += 150  // +80 MaxHP permanent
            } else {
                value += 100  // Generic buff
            }
        }
        // Healing chips
        else if (isHealingChip(chipId)) {
            var hpMissing = playerObj._maxHealth - playerObj._currHealth
            if (hpMissing > 0) {
                var healEstimate = beamEstimateHeal(chipId, simWis)
                var effectiveHeal = min(hpMissing, healEstimate)
                value += effectiveHeal * 1.5

                // Low HP urgency
                var hpRatio = playerObj._currHealth / playerObj._maxHealth
                if (hpRatio < 0.3) value *= 3.0
                else if (hpRatio < 0.5) value *= 2.0
            } else {
                value += 10  // Minimal if full HP
            }
        }
        // Shield chips
        else if (isShieldChip(chipId)) {
            value += 150
            // Threat-dependent
            var threat = 0
            if (fieldMap != null) threat = fieldMap.getThreatAtCell(partial['simPos'])
            if (threat > 300) value *= 2.0
        }
        // Damage return chips — gate on enemy proximity
        else if (isDamageReturnChip(chipId)) {
            var drDuration = (chipId == CHIP_BRAMBLE) ? 1 : (chipId == CHIP_THORN) ? 2 : 3
            if (predictEnemyCanAttackWithin(partial['simPos'], targetObj, drDuration)) {
                value += 200
                var threat = 0
                if (fieldMap != null) threat = fieldMap.getThreatAtCell(partial['simPos'])
                if (threat > 300) value *= 2.0
            } else {
                value += 10  // Minimal value — save for later
            }
        }
        // Debuff/denial chips
        else if (isDebuffChip(chipId)) {
            if (chipId == CHIP_SOPORIFIC || chipId == CHIP_BALL_AND_CHAIN) {
                value += 200 * (1 + simMag / 500)
                // Lock-down bonus if poison active
                var hasPoison = false
                for (var a in partial['actions']) {
                    if (a.type == Action.ACTION_DOT) { hasPoison = true; break }
                }
                if (hasPoison) value += 150
            } else if (chipId == CHIP_LIBERATION) {
                value += 120
            } else {
                value += 80
            }
        }
        // Resource chips
        else if (isResourceChip(chipId)) {
            if (chipId == CHIP_LEATHER_BOOTS) {
                value += 150  // +2 MP enables movement
            }
        }
        // Utility chips (Grapple, Boxing Glove)
        else if (isUtilityChip(chipId)) {
            if (chipId == CHIP_GRAPPLE) {
                value += 200
                // Bonus if we have short-range attacks that need closer enemy
                var shortRangeCount = 0
                for (var cid in mapKeys(arsenalObj.playerEquippedChips)) {
                    if (mapContainsKey(partial['chipUsed'], cid)) continue
                    var cObj = arsenalObj.playerEquippedChips[cid]
                    if (cObj._maxRange <= 4 && !isHealingChip(cid) && !isOffensiveBuff(cid) &&
                        !isShieldChip(cid) && !isDamageReturnChip(cid) && !isResourceChip(cid)) {
                        shortRangeCount++
                    }
                }
                if (shortRangeCount > 0) value += 100 * shortRangeCount
            } else {
                value += 150
            }
        }

    } else if (actionInfo['type'] == 'weapon') {
        var wid = actionInfo['id']
        var bd = arsenalObj.getDamageBreakdown(simStr, simMag, simWis, simSci, wid)
        var directDmg = bd['direct']
        var dotDmg = bd['dot']
        var novaDmg = bd['nova']

        value += directDmg * 2.0
        value += dotDmg * 1.5
        value += novaDmg * 2.5

        // Poison weapon antidote awareness
        if (dotDmg > 0) {
            var antidoteCd = 0
            var tracker = new CooldownTracker(targetObj)
            antidoteCd = tracker.getCooldownRemaining(targetObj._id, CooldownTracker.CHIP_ANTIDOTE_ID)
            if (antidoteCd >= 3) value += dotDmg * 0.5
            else if (antidoteCd == 0) value -= dotDmg * 0.5
        }

        // Kill proximity
        if (enemyHP > 0 && (cumDamage + directDmg + dotDmg + novaDmg) / enemyHP > 0.7) {
            value *= 3.0
        }

        // Swap penalty
        if (actionInfo['needsSwap']) {
            value -= 50
        }

    } else if (actionInfo['type'] == 'move') {
        var moveTargetPos = actionInfo['targetCell']
        var targetEnemyPos = targetObj._cellPos
        var newDist = getCellDistance(moveTargetPos, targetEnemyPos)
        var oldDist = getCellDistance(partial['simPos'], targetEnemyPos)

        if (newDist != null && oldDist != null) {
            // Count attacks enabled from new position vs current position
            var newAttacks = beamCountAttacksFromPos(moveTargetPos, targetEnemyPos, arsenalObj, partial)
            var oldAttacks = beamCountAttacksFromPos(partial['simPos'], targetEnemyPos, arsenalObj, partial)
            var enabledDelta = newAttacks - oldAttacks
            value += enabledDelta * 150
            value += newAttacks * 50  // Base value for attacks in range

            // Approach bonus
            if (newDist < oldDist) {
                value += (oldDist - newDist) * 50
            }

            // Cover bonus: prefer cells with less enemy LoS
            if (fieldMap != null) {
                var enemies = fieldMap.getEnemySubMap()
                var exposureNew = 0
                var exposureOld = 0
                for (var eid in mapKeys(enemies)) {
                    if (!isDead(eid)) {
                        var eCell = enemies[eid]._cellPos
                        if (eCell != null) {
                            if (lineOfSight(moveTargetPos, eCell)) exposureNew++
                            if (lineOfSight(partial['simPos'], eCell)) exposureOld++
                        }
                    }
                }
                if (exposureNew < exposureOld) value += (exposureOld - exposureNew) * 100
            }
        }
    }

    return value
}

// Extend a beam candidate with a new action
function beamExtendCandidate(partial, actionInfo, value, targetObj) {
    // Clone actions
    var newActions = []
    for (var a in partial['actions']) push(newActions, a)

    var newChipUsed = [:]
    for (var k in mapKeys(partial['chipUsed'])) newChipUsed[k] = true

    var newWeaponUses = [:]
    for (var k in mapKeys(partial['weaponUses'])) newWeaponUses[k] = partial['weaponUses'][k]

    var newTP = partial['simTP']
    var newMP = partial['simMP']
    var newPos = partial['simPos']
    var newWeapon = partial['simWeapon']
    var newStr = partial['simStr']
    var newMag = partial['simMag']
    var newWis = partial['simWis']
    var newSci = partial['simSci']
    var newAgi = partial['simAgi']
    var newCumDamage = partial['cumDamage']
    var newMoveCount = partial['moveCount']

    if (actionInfo['type'] == 'chip') {
        var chipId = actionInfo['id']
        var targetEntity = actionInfo['isSelf'] ? null : targetObj
        var action = new Action(actionInfo['actionType'], -1, chipId, actionInfo['targetCell'], targetEntity)
        push(newActions, action)
        newTP -= actionInfo['cost']
        newChipUsed[chipId] = true

        // Update simulated stats for buffs
        if (chipId == CHIP_STEROID) newStr += 200
        else if (chipId == CHIP_DOPING) newStr += 100
        else if (chipId == CHIP_WIZARDRY) newMag += 160
        else if (chipId == CHIP_KNOWLEDGE) newWis += 260
        else if (chipId == CHIP_WARM_UP) newAgi += 180
        else if (chipId == CHIP_PRISM) {
            newStr += 60; newMag += 60; newWis += 60; newSci += 60; newAgi += 60
        }
        else if (chipId == CHIP_ADRENALINE) newTP += 5
        else if (chipId == CHIP_LEATHER_BOOTS) newMP += 2

        // Update cumulative damage estimate using SIMULATED stats (post-buff)
        if (actionInfo['actionType'] == Action.ACTION_DIRECT || actionInfo['actionType'] == Action.ACTION_DOT) {
            var bd = arsenal.getDamageBreakdown(newStr, newMag, newWis, newSci, chipId)
            if (bd != null) {
                newCumDamage += bd['direct'] + bd['dot'] + bd['nova']
            }
        }

    } else if (actionInfo['type'] == 'weapon') {
        var wid = actionInfo['id']
        if (actionInfo['needsSwap']) {
            var swapAction = new Action(Action.ACTION_WEAPON_SWAP, wid, -1, -1, null)
            push(newActions, swapAction)
            newWeapon = wid
        }
        var attackAction = new Action(Action.ACTION_DIRECT, wid, -1, actionInfo['targetCell'], targetObj)
        push(newActions, attackAction)
        newTP -= actionInfo['cost']

        var uses = 0
        if (mapContainsKey(newWeaponUses, wid)) uses = newWeaponUses[wid]
        newWeaponUses[wid] = uses + 1
        newWeapon = wid

        // Update cumulative damage using simulated stats
        var bd = arsenal.getDamageBreakdown(newStr, newMag, newWis, newSci, wid)
        if (bd != null) {
            newCumDamage += bd['direct'] + bd['dot'] + bd['nova']
        }

    } else if (actionInfo['type'] == 'move') {
        var moveAction = new Action(Action.MOVEMENT_APPROACH, -1, -1, actionInfo['targetCell'], null)
        push(newActions, moveAction)
        var mpCost = actionInfo['mpCost']
        if (mpCost == null || mpCost == 999) mpCost = 1
        newMP -= mpCost
        newPos = actionInfo['targetCell']
        newMoveCount++
    }

    return [
        'actions': newActions,
        'simTP': newTP,
        'simMP': newMP,
        'simPos': newPos,
        'simWeapon': newWeapon,
        'simStr': newStr,
        'simMag': newMag,
        'simWis': newWis,
        'simSci': newSci,
        'simAgi': newAgi,
        'chipUsed': newChipUsed,
        'weaponUses': newWeaponUses,
        'cumScore': partial['cumScore'] + value,
        'cumDamage': newCumDamage,
        'moveCount': newMoveCount,
        'wMaxUses': partial['wMaxUses']
    ]
}

// Helper: count unused poison chips
function beamCountUnusedPoisonChips(partial, arsenalObj) {
    var count = 0
    for (var chipId in mapKeys(arsenalObj.playerEquippedChips)) {
        if (isPoisonChip(chipId) && !mapContainsKey(partial['chipUsed'], chipId)) {
            if (getCooldown(chipId, getEntity()) == 0) count++
        }
    }
    return count
}

// Helper: count unused denial chips (Soporific, Ball and Chain)
function beamCountUnusedDenialChips(partial, arsenalObj) {
    var count = 0
    for (var chipId in mapKeys(arsenalObj.playerEquippedChips)) {
        if ((chipId == CHIP_SOPORIFIC || chipId == CHIP_BALL_AND_CHAIN) &&
            !mapContainsKey(partial['chipUsed'], chipId)) {
            if (getCooldown(chipId, getEntity()) == 0) count++
        }
    }
    return count
}

// Helper: count unused healing chips
function beamCountUnusedHealChips(partial, arsenalObj) {
    var count = 0
    for (var chipId in mapKeys(arsenalObj.playerEquippedChips)) {
        if (isHealingChip(chipId) && !mapContainsKey(partial['chipUsed'], chipId)) {
            if (getCooldown(chipId, getEntity()) == 0) count++
        }
    }
    return count
}

// Helper: count unused damage return chips
function beamCountUnusedReturnChips(partial, arsenalObj) {
    var count = 0
    for (var chipId in mapKeys(arsenalObj.playerEquippedChips)) {
        if (isDamageReturnChip(chipId) && !mapContainsKey(partial['chipUsed'], chipId)) {
            if (getCooldown(chipId, getEntity()) == 0) count++
        }
    }
    return count
}

// Helper: check for unused Nova weapons
function beamHasUnusedNovaWeapon(partial, arsenalObj) {
    for (var wid in mapKeys(arsenalObj.playerEquippedWeapons)) {
        var bd = getCachedDamageBreakdown(wid)
        if (bd != null && bd['nova'] > 0) {
            var uses = 0
            if (mapContainsKey(partial['weaponUses'], wid)) uses = partial['weaponUses'][wid]
            var maxUse = mapContainsKey(partial['wMaxUses'], wid) ? partial['wMaxUses'][wid] : 1
            if (uses < maxUse) return true
        }
    }
    return false
}

// Helper: count unused shield chips
function beamCountUnusedShieldChips(partial, arsenalObj) {
    var count = 0
    for (var chipId in mapKeys(arsenalObj.playerEquippedChips)) {
        if (isShieldChip(chipId) && !mapContainsKey(partial['chipUsed'], chipId)) {
            if (getCooldown(chipId, getEntity()) == 0) count++
        }
    }
    return count
}

// Helper: count unused weapon attacks
function beamCountUnusedWeapons(partial, arsenalObj) {
    var count = 0
    for (var wid in mapKeys(arsenalObj.playerEquippedWeapons)) {
        var uses = 0
        if (mapContainsKey(partial['weaponUses'], wid)) uses = partial['weaponUses'][wid]
        var maxUse = mapContainsKey(partial['wMaxUses'], wid) ? partial['wMaxUses'][wid] : 1
        if (uses < maxUse) count++
    }
    return count
}

// Helper: count attacks enabled from a position
function beamCountAttacksFromPos(fromPos, targetPos, arsenalObj, partial) {
    var count = 0
    var dist = getCellDistance(fromPos, targetPos)
    if (dist == null) return 0

    // Check weapons
    for (var wid in mapKeys(arsenalObj.playerEquippedWeapons)) {
        var wObj = arsenalObj.playerEquippedWeapons[wid]
        if (dist >= wObj._minRange && dist <= wObj._maxRange) count++
    }
    // Check attack chips
    for (var chipId in mapKeys(arsenalObj.playerEquippedChips)) {
        if (mapContainsKey(partial['chipUsed'], chipId)) continue
        if (isHealingChip(chipId) || isOffensiveBuff(chipId) || isShieldChip(chipId) ||
            isDamageReturnChip(chipId) || isResourceChip(chipId)) continue
        var chipObj = arsenalObj.playerEquippedChips[chipId]
        if (dist >= chipObj._minRange && dist <= chipObj._maxRange) count++
    }
    return count
}

// Helper: estimate healing from a chip
function beamEstimateHeal(chipId, wisdom) {
    if (chipId == CHIP_REGENERATION) return 500
    if (chipId == CHIP_REMISSION) return 71 * (1 + wisdom / 100)
    if (chipId == CHIP_CURE) return 200 * (1 + wisdom / 100)
    if (chipId == CHIP_DRIP) return 100 * (1 + wisdom / 100)
    return 50 * (1 + wisdom / 100)
}

// Beam diversity helpers
function beamHasDefensiveAction(candidate) {
    for (var action in candidate['actions']) {
        if (action.chip != null && action.chip != -1) {
            if (isShieldChip(action.chip) || isHealingChip(action.chip)) return true
            if (isDamageReturnChip(action.chip)) return true
        }
    }
    return false
}

function beamHasUtilityAction(candidate) {
    for (var action in candidate['actions']) {
        if (action.type == Action.ACTION_DOT) return true
        if (action.type == Action.ACTION_DEBUFF) return true
        if (action.chip != null && action.chip != -1 && isOffensiveBuff(action.chip)) return true
    }
    return false
}
